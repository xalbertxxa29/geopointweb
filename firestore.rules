rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    
    match /mail_queue/{id} {
      allow create: if request.auth != null;
      allow read: if false; // Por seguridad, nadie debe leer la cola de correos desde la app
    }

    function callerUsername() {
      return request.auth.token.email.split('@')[0].lower();
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(callerUsername())).data.tipo.lower()
          in ['admin', 'administrador'];
    }

    // ── tareas (incident reports) ─────────────────────────────────────────
    match /tareas/{tareaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // MODIFICACIÓN: Permitimos 'update' a usuarios autenticados para que puedan finalizar visitas
      allow update: if isAuthenticated(); 
      allow delete: if isAdmin();

      // Sub-colecciones (actividades, fotos, etc.)
      match /{subCol}/{docId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ── usuarios ──────────────────────────────────────────────────────────
    match /usuarios/{userId} {
      allow read: if isAuthenticated() && (callerUsername() == userId || isAdmin());
      allow write: if isAdmin();
    }

    // ── CLIENTES (unit catalog) ───────────────────────────────────────────
    match /CLIENTES/{clienteId} {
      allow read, write: if true;
      match /UNIDADES/{unidadId} {
        allow read, write: if true;
      }
    }

    // ── CLIENTE (Nueva colección singular) ─────────────────────────────
    match /CLIENTE/{document=**} {
      allow read, write: if true;
    }

    // ── logs (auditoría) ────────────────────────────────────────────────
    match /logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // ── Default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
